---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import AwardsPage from '@/components/pages/AwardsPage.astro';
import Footer from '@/components/Footer.astro';
import { useTranslations } from '@/i18n/translations';

const locale = 'pl' as const;
const t = useTranslations(locale);
---

<Layout title={t('awards.meta.title')} description={t('awards.meta.description')} locale={locale}>
  <Header locale={locale} showLogoAlways={true} />
  <AwardsPage locale={locale} />
  <Footer locale={locale} />
</Layout>
