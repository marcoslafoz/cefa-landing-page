---
import type { Locale } from '@/i18n/translations';
import { useTranslations } from '@/i18n/translations';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import Section from '@/components/ui/Section.astro';
import brands from '@/data/brands.json';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<Section id="clients" background="white" padding="xl">
  <!-- Cabecera -->
  <SectionHeader
    layout="split"
    eyebrow={t('clients.eyebrow')}
    title={t('clients.title')}
    description={t('clients.subtitle')}
    class="mb-16"
  />

  <!-- Marquesina (Marquee) -->
  <div
    class="reveal relative overflow-hidden mask-[linear-gradient(to_right,transparent_0%,black_8%,black_92%,transparent_100%)] [-webkit-mask-image:linear-gradient(to_right,transparent_0%,black_8%,black_92%,transparent_100%)]"
    aria-label={t('clients.eyebrow')}
  >
    <div
      id="marquee-track"
      class="flex items-center w-max motion-safe:animate-[marquee_28s_linear_infinite]"
    >
      {
        [...brands, ...brands, ...brands, ...brands].map((brand, index) => (
          <div
            class={`mx-5 flex items-center justify-center group cursor-default shrink-0 ${index >= 9 ? 'motion-reduce:hidden' : ''}`}
          >
            <img
              src={`/images/brands/${brand.file}`}
              alt={brand.name}
              width="128"
              height="40"
              loading="lazy"
              class="h-10 w-32 object-contain opacity-60 group-hover:opacity-100 filter grayscale group-hover:grayscale-0 transition-all duration-500"
            />
          </div>
        ))
      }
    </div>
  </div>

  <!-- Cuadrícula estática para movimiento reducido -->
  <div
    class="hidden motion-reduce:grid! grid-cols-2 sm:grid-cols-4 lg:grid-cols-7 gap-y-12 gap-x-8 mt-12"
    id="brands-static"
    aria-hidden="true"
  >
    {
      brands.map((brand) => (
        <div class="flex items-center justify-center p-2 group transition-all">
          <img
            src={`/images/brands/${brand.file}`}
            alt={brand.name}
            width="128"
            height="40"
            loading="lazy"
            class="h-10 w-40 object-contain opacity-70 group-hover:opacity-100 transition-all duration-300"
          />
        </div>
      ))
    }
  </div>
</Section>

<script>
  let marqueeObserver: IntersectionObserver | null = null;

  function initMarqueePause() {
    const track = document.getElementById('marquee-track');
    const section = document.getElementById('clientes');
    if (!track || !section || section.dataset.observed === 'true') return;

    marqueeObserver?.disconnect();
    marqueeObserver = new IntersectionObserver(
      (entries) => {
        (track as HTMLElement).style.animationPlayState = entries[0].isIntersecting
          ? 'running'
          : 'paused';
      },
      { threshold: 0 }
    );
    marqueeObserver.observe(section);
    section.dataset.observed = 'true';
  }

  document.addEventListener('astro:page-load', initMarqueePause);
  document.addEventListener('astro:before-swap', () => {
    marqueeObserver?.disconnect();
  });
</script>
