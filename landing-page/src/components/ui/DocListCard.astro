---
import { getFileSize } from '@/utils/files';

interface Props {
  title: string;
  href: string;
  type?: string;
  size?: string;
}

const { title, href, type, size: propSize } = Astro.props;
const size = propSize || getFileSize(href);
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class="group flex items-center justify-between border-b border-cefa-navy/10 py-4 transition-all duration-300 hover:bg-cefa-navy/1"
>
  <div class="flex items-center gap-4 flex-1 min-w-0">
    <!-- Chevron rojo -->
    <div class="shrink-0 w-3">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="3"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="text-cefa-red w-full h-auto transform transition-transform duration-300 group-hover:translate-x-0.5"
      >
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </div>

    <!-- Título y metadatos -->
    <div class="flex items-baseline gap-2 min-w-0">
      <h3
        class="text-lg text-cefa-navy/70 font-normal transition-colors group-hover:text-cefa-red truncate"
      >
        {title}
      </h3>

      {
        (type || size) && (
          <span class="text-xs text-cefa-navy/30 font-normal whitespace-nowrap">
            ({type ? type.toUpperCase() : ''}
            {type && size ? ' | ' : ''}
            {size ? size : ''})
          </span>
        )
      }
    </div>
  </div>
</a>
