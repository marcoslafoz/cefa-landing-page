---
interface Props {
  as?: any;
  href?: string;
  class?: string;
  padding?: string;
  interactive?: boolean;
  [key: string]: any;
}

const {
  as: Element = 'div',
  href,
  class: className,
  padding = 'pt-6 px-6 pb-0 lg:pt-8 lg:px-8 lg:pb-0',
  interactive = true,
  ...rest
} = Astro.props as Props;

const Tag = href ? 'a' : Element;
---

<Tag
  href={href}
  class:list={[
    'group relative flex flex-col bg-white border border-cefa-navy/2 backface-hidden transform-gpu transition-all duration-500 reveal',
    padding,
    interactive && 'hover:border-cefa-navy/8 cursor-pointer',
    className,
  ]}
  {...rest}
>
  <slot />
</Tag>
