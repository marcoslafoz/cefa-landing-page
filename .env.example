###############################################################################
# CEFA – Variables de entorno para Docker Compose
# Copia este archivo como ".env" en la raíz del monorepo y rellena los valores.
# NUNCA hagas commit del archivo ".env" con secretos reales.
###############################################################################

# ── Payload CMS ───────────────────────────────────────────────────────────────
# Cadena aleatoria de al menos 32 caracteres. Generala con:
#   openssl rand -hex 32
PAYLOAD_SECRET=CAMBIA_ESTO_POR_UNA_CADENA_SECRETA_LARGA

# URL pública del CMS (visible en el navegador del editor)
# En producción sería https://cms.tudominio.com
PAYLOAD_PUBLIC_URL=http://localhost

# ── URLs internas de la red Docker ───────────────────────────────────────────
# Normalmente no hace falta cambiarlas salvo que renombres los servicios en compose.yml
DATABASE_URL=mongodb://mongo:27017/payloadcms
PAYLOAD_CMS_URL=http://payload:3000
LIBRETRANSLATE_URL=http://libretranslate:5000/translate
PUBLISH_WEBHOOK_URL=http://orchestrator:4000/webhook/publish

# ── Webhook / Orquestador ─────────────────────────────────────────────────────
# Secreto compartido entre Payload y el Orchestrator.
# Cámbialo por algo aleatorio: openssl rand -hex 24
WEBHOOK_SECRET=CAMBIA_ESTO_POR_OTRO_SECRETO

# ── Nginx ─────────────────────────────────────────────────────────────────────
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ── Cloudflare Turnstile (formulario de contacto) ─────────────────────────────
PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# ── Transporte de email del formulario de contacto ────────────────────────────
# Valores posibles: "console" (imprime en log del servidor) | "smtp" (envía email real)
CONTACT_TRANSPORT=console
CONTACT_TO_EMAIL=info@cefa.es

# SMTP (solo necesario si CONTACT_TRANSPORT=smtp)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=usuario@cefa.es
SMTP_PASS=contraseña_smtp
