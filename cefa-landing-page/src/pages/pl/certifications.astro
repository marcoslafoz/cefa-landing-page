---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import CertificationsPage from '@/components/pages/CertificationsPage.astro';
import Footer from '@/components/Footer.astro';
import { getCertificationsContent } from '@/lib/cms';

const locale = 'pl' as const;
const certContent = await getCertificationsContent(locale);
---

<Layout
  title={certContent?.meta?.title ?? ''}
  description={certContent?.meta?.description ?? ''}
  locale={locale}
>
  <Header locale={locale} showLogoAlways={true} />
  <CertificationsPage locale={locale} />
  <Footer locale={locale} />
</Layout>
