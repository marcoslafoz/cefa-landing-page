---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import {
  useTranslations,
  getLocalePath,
  locales,
  defaultLocale,
  type Locale,
} from '@/i18n/translations';
import Button from '@/components/ui/Button.astro';

const segments = Astro.url.pathname.split('/').filter(Boolean);
const firstSegment = segments[0] as Locale;
const locale: Locale = locales.includes(firstSegment) ? firstSegment : defaultLocale;
const t = useTranslations(locale);
---

<Layout title={`404 – ${t('404.title')} | CEFA`} description={t('404.subtitle')} locale={locale}>
  <Header locale={locale} showLogoAlways={true} />

  <main
    class="min-h-screen bg-white flex flex-col items-center justify-center px-6 text-center"
    id="main-content"
  >
    <!-- 404 Grande -->
    <div class="relative flex flex-col items-center mb-12">
      <div
        class="text-[clamp(8rem,25vw,20rem)] font-extrabold leading-none tracking-tighter text-cefa-navy/10 select-none"
        aria-hidden="true"
      >
        404
      </div>

      <!-- Línea de acento roja -->
      <div class="absolute bottom-[10%] w-16 h-1 bg-cefa-red rounded-full"></div>
    </div>

    <h1
      class="text-[clamp(1.75rem,4vw,3rem)] font-extrabold text-cefa-navy leading-tight tracking-tight mb-4"
    >
      {t('404.title')}
    </h1>

    <p class="text-base text-cefa-navy/50 leading-relaxed mb-10 max-w-md">
      {t('404.subtitle')}
    </p>

    <Button href={getLocalePath(locale)} variant="primary">{t('404.cta')}</Button>
  </main>

  <Footer locale={locale} />
</Layout>
