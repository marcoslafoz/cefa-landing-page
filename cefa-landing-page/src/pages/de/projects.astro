---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import RdProjectsPage from '@/components/pages/RdProjectsPage.astro';
import Footer from '@/components/Footer.astro';
import { getRDContent } from '@/lib/cms';

const locale = 'de' as const;
const rdContent = await getRDContent(locale);
---

<Layout
  title={rdContent?.meta?.title ?? ''}
  description={rdContent?.meta?.description ?? ''}
  locale={locale}
>
  <Header locale={locale} showLogoAlways={true} />
  <RdProjectsPage locale={locale} />
  <Footer locale={locale} />
</Layout>
