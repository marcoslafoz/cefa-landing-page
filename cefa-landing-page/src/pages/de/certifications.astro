---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import CertificationsPage from '@/components/pages/CertificationsPage.astro';
import Footer from '@/components/Footer.astro';
import { useTranslations } from '@/i18n/translations';

const locale = 'de' as const;
const t = useTranslations(locale);
---

<Layout
  title={t('certifications.meta.title')}
  description={t('certifications.meta.description')}
  locale={locale}
>
  <Header locale={locale} showLogoAlways={true} />
  <CertificationsPage locale={locale} />
  <Footer locale={locale} />
</Layout>
