---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import AwardsPage from '@/components/pages/AwardsPage.astro';
import Footer from '@/components/Footer.astro';
import { getAwards } from '@/lib/cms';

const locale = 'de' as const;
const awardsData = await getAwards(locale);
---

<Layout
  title={awardsData?.meta?.title ?? ''}
  description={awardsData?.meta?.description ?? ''}
  locale={locale}
>
  <Header locale={locale} showLogoAlways={true} />
  <AwardsPage locale={locale} />
  <Footer locale={locale} />
</Layout>
