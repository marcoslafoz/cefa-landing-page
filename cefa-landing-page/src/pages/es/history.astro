---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import HistoryPage from '@/components/pages/HistoryPage.astro';
import Footer from '@/components/Footer.astro';
import { getHistoryContent } from '@/lib/cms';

const locale = 'es' as const;
const historyData = await getHistoryContent(locale);
---

<Layout
  title={historyData?.meta?.title ?? ''}
  description={historyData?.meta?.description ?? ''}
  locale={locale}
>
  <Header locale={locale} showLogoAlways={true} />
  <HistoryPage locale={locale} />
  <Footer locale={locale} />
</Layout>
