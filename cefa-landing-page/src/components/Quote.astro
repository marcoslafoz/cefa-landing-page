---
import type { Locale } from '@/i18n/translations';
import Section from '@/components/ui/Section.astro';
import { getQuote } from '@/lib/cms';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const cmsQuote = await getQuote(locale);

const quoteText = cmsQuote?.text ?? '';
const quotePhilosophy = cmsQuote?.philosophy ?? '';
---

<!-- Sección de cita compacta con fondo blanco -->
<Section
  background="white"
  padding="none"
  class="border-b border-cefa-navy/5 pt-0 pb-16 lg:pb-24"
  aria-label="Company quote"
>
  <div class="text-center reveal">
    <svg
      class="mx-auto mb-5 text-cefa-red"
      width="48"
      height="36"
      viewBox="0 0 48 36"
      fill="currentColor"
      aria-hidden="true"
    >
      <path
        d="M0 36V21.6C0 9.67 7.19 2.74 21.56 0L23.4 4.03C16.86 5.47 12.93 8.64 11.63 13.54H20.57V36H0ZM27.43 36V21.6C27.43 9.67 34.62 2.74 49 0L50.83 4.03C44.3 5.47 40.36 8.64 39.06 13.54H48V36H27.43Z"
      ></path>
    </svg>

    <blockquote class="relative">
      <p
        class="text-[clamp(1.2rem,3.5vw,1.85rem)] text-cefa-navy font-light leading-[1.3] tracking-tight mb-8 mx-auto max-w-212.5"
      >
        {quoteText}
      </p>
      <p class="mt-8 flex flex-col items-center">
        <span
          class="text-[0.7rem] uppercase tracking-[0.45em] text-cefa-gray font-medium whitespace-nowrap leading-none"
        >
          {quotePhilosophy}
        </span>
      </p>
    </blockquote>
  </div>
</Section>
