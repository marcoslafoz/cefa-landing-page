---
import type { Locale } from '@/i18n/translations';
import { useTranslations, getLocalePath } from '@/i18n/translations';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<div
  id="cookie-banner"
  class="fixed bottom-0 left-0 right-0 z-100 transform translate-y-full opacity-0 pointer-events-none transition-all duration-700 ease-smooth"
  aria-labelledby="cookie-title"
>
  <div
    class="bg-cefa-navy-dark/60 backdrop-blur-2xl border-t border-white/10 shadow-[0_-10px_40px_-15px_var(--color-shadow-dark)]"
  >
    <div class="site-container py-4 md:py-5">
      <div class="flex flex-col lg:flex-row items-center justify-between gap-6 lg:gap-12">
        <div class="flex-1 text-center lg:text-left">
          <p
            id="cookie-desc"
            class="text-[13px] md:text-sm text-white/70 leading-relaxed font-light"
          >
            <span class="text-white font-bold mr-1">{t('cookie.banner.title')}:</span>
            {t('cookie.banner.description')}
            <a
              href={getLocalePath(locale, '/cookies')}
              class="text-white underline underline-offset-4 hover:text-cefa-red transition-colors ml-1 font-medium"
            >
              {t('cookie.banner.policy')}
            </a>
          </p>
        </div>

        <div class="flex items-center gap-3 shrink-0">
          <button
            id="reject-cookies"
            class="px-4 py-2 bg-transparent text-white/50 text-[10px] font-bold uppercase tracking-widest hover:text-white transition-colors"
          >
            {t('cookie.banner.reject')}
          </button>
          <button
            id="accept-all-cookies"
            class="px-6 py-2.5 bg-white text-cefa-navy-dark hover:bg-cefa-red hover:text-white text-[10px] font-bold uppercase tracking-widest transition-all duration-300"
          >
            {t('cookie.banner.accept')}
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function handleCookieConsent() {
    const banner = document.getElementById('cookie-banner');
    const acceptBtn = document.getElementById('accept-all-cookies');
    const rejectBtn = document.getElementById('reject-cookies');

    if (!banner || !acceptBtn || !rejectBtn) return;

    const CONSENT_KEY = 'cefa-cookie-consent';
    const consent = localStorage.getItem(CONSENT_KEY);

    if (!consent) {
      setTimeout(() => {
        banner.classList.remove('translate-y-full', 'opacity-0', 'pointer-events-none');
      }, 2000);
    }

    function setConsent(value: string) {
      localStorage.setItem(CONSENT_KEY, value);
      if (banner) banner.classList.add('translate-y-full', 'opacity-0', 'pointer-events-none');
      window.dispatchEvent(new CustomEvent('cookie-consent-updated', { detail: value }));
    }

    acceptBtn.addEventListener('click', () => setConsent('accepted'));
    rejectBtn.addEventListener('click', () => setConsent('rejected'));
  }

  document.addEventListener('astro:page-load', handleCookieConsent);
  handleCookieConsent();
</script>
