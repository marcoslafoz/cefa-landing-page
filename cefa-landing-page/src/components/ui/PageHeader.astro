---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  class?: string;
}

const { eyebrow, title, description, class: className } = Astro.props;
---

<header class:list={['relative bg-white pt-28 pb-10 overflow-hidden', className]}>
  <div class="site-container relative z-10">
    <div class="max-w-3xl">
      {eyebrow && <p class="eyebrow mb-2 reveal">{eyebrow}</p>}
      <h1 class="heading-xl mb-5 reveal">
        {title}
      </h1>
      {description && <p class="body-lead max-w-2xl reveal">{description}</p>}
    </div>
  </div>
</header>
