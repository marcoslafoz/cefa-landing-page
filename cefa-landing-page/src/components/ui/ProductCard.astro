---
import ArrowIcon from './ArrowIcon.astro';

interface Props {
  category: string;
  title: string;
  desc: string;
  image: string;
  alt: string;
  ctaText: string;
  delay?: number;
  id?: string;
}

const { category, title, desc, image, alt, ctaText, delay = 0, id } = Astro.props;
---

<article
  id={id}
  class="reveal group relative lg:flex-1 lg:hover:flex-[2.5] transition-all duration-700 ease-[cubic-bezier(0.25,1,0.5,1)] overflow-hidden cursor-pointer h-70 lg:h-full border border-black/5"
  style={delay ? `transition-delay: ${delay}ms;` : undefined}
>
  {/* Imagen de fondo */}
  <div class="absolute inset-0 transition-transform duration-1000 ease-out group-hover:scale-110">
    <img
      src={image}
      alt={alt}
      class="w-full h-full object-cover grayscale-[0.2] group-hover:grayscale-0"
      loading="lazy"
      width="800"
      height="1200"
      decoding="async"
    />
    {/* Degradados de superposición */}
    <div
      class="absolute inset-0 bg-linear-to-t from-cefa-navy/90 via-cefa-navy/40 to-transparent lg:opacity-80 group-hover:opacity-60 transition-opacity duration-500"
    >
    </div>
    <div
      class="absolute inset-0 bg-linear-to-b from-black/40 via-transparent to-transparent opacity-40"
    >
    </div>
  </div>

  {/* Información superior */}
  <div
    class="absolute top-8 left-8 transition-all duration-500 transform lg:-translate-y-4 lg:opacity-0 group-hover:translate-y-0 group-hover:opacity-100"
  >
    <span class="text-white/60 text-[0.65rem] font-bold uppercase tracking-widest">
      {category}
    </span>
  </div>

  {/* Contenido inferior */}
  <div
    class="absolute bottom-0 left-0 right-0 p-8 pt-20 bg-linear-to-t from-cefa-navy/90 to-transparent lg:from-transparent"
  >
    <div class="relative z-10">
      <h3
        class="text-white font-light text-xl lg:text-2xl leading-tight mb-3 transform transition-transform duration-500 group-hover:translate-x-1"
      >
        {title}
      </h3>

      <div class="overflow-hidden">
        <p
          class="text-white/70 text-sm leading-relaxed lg:max-h-0 lg:opacity-0 group-hover:max-h-32 group-hover:opacity-100 transition-all duration-700 ease-in-out"
        >
          {desc}
        </p>
      </div>

      <div
        class="mt-6 transform translate-y-8 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500 delay-100"
      >
        <a
          href="#contact"
          class="inline-flex items-center gap-2 text-cefa-red text-[0.7rem] font-bold uppercase tracking-widest hover:gap-3 transition-all font-sans"
        >
          {ctaText}
          <ArrowIcon />
        </a>
      </div>
    </div>
  </div>

  {/* Etiqueta lateral (Visible cuando no hay hover / en escritorio) */}
  <div
    class="hidden lg:block absolute right-6 top-1/2 -translate-y-1/2 rotate-90 origin-right transition-opacity duration-300 group-hover:opacity-0 pointer-events-none"
  >
    <span
      class="text-white/30 text-[0.6rem] font-bold uppercase tracking-[0.3em] whitespace-nowrap"
    >
      {title.split(' ')[0]}
    </span>
  </div>
</article>
