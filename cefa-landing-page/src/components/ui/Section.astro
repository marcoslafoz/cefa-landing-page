---
interface Props {
  id?: string;
  class?: string;
  background?: 'white' | 'gray' | 'navy' | 'navy-dark' | 'none';
  padding?: 'none' | 'sm' | 'md' | 'lg' | 'xl';
  container?: boolean;
}

const { id, class: className, background = 'none', padding = 'md', container = true } = Astro.props;

const bgClasses = {
  white: 'bg-white',
  gray: 'bg-gray-50',
  navy: 'bg-cefa-navy text-white',
  'navy-dark': 'bg-cefa-navy-dark text-white',
  none: '',
};

const paddingClasses = {
  none: '',
  sm: 'py-8 lg:py-12',
  md: 'py-12 lg:py-16',
  lg: 'py-16 lg:py-24',
  xl: 'py-20 lg:py-32',
};
---

<section
  id={id}
  class:list={[
    bgClasses[background],
    paddingClasses[padding],
    'relative overflow-hidden',
    className,
  ]}
>
  {
    container ? (
      <div class="site-container">
        <slot />
      </div>
    ) : (
      <slot />
    )
  }
</section>
