---
import type { Locale } from '@/i18n/translations';
import { useTranslations } from '@/i18n/translations';
import Section from '@/components/ui/Section.astro';
import { getMission, getHero } from '@/lib/cms';
import StatItem from '@/components/ui/StatItem.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const cmsData = await getMission(locale);
const heroData = await getHero(locale);

const missionData =
  cmsData?.mission &&
  typeof cmsData.mission === 'object' &&
  !Array.isArray(cmsData.mission) &&
  cmsData.mission.title
    ? cmsData.mission
    : cmsData;

const missionTitle = missionData?.title || t('mission.title');
const missionDescription = missionData?.body1 || t('mission.body1');
const missionDescription2 = missionData?.body2 || t('mission.body2');

const cmsStats = heroData?.stats || [];
const stats = [
  {
    value: cmsStats[0]?.value || t('stats.years.value'),
    label: cmsStats[0]?.label || t('stats.years.label'),
  },
  {
    value: cmsStats[1]?.value || t('stats.plants.value'),
    label: cmsStats[1]?.label || t('stats.plants.label'),
  },
  {
    value: cmsStats[2]?.value || t('stats.employees.value'),
    label: cmsStats[2]?.label || t('stats.employees.label'),
  },
  {
    value: cmsStats[3]?.value || t('stats.cert.value'),
    label: cmsStats[3]?.label || t('stats.cert.label'),
  },
];
---

<Section id="mission" background="white" class="pb-16 lg:pb-24">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
    <!-- Columna izquierda: Título principal -->
    <div class="reveal">
      <h2
        class="text-[clamp(2rem,5vw,3.5rem)] font-light leading-[1.1] text-cefa-navy tracking-[-0.02em]"
      >
        {missionTitle}
      </h2>
    </div>

    <!-- Columna derecha: Texto y CTA -->
    <div class="reveal flex flex-col gap-10 lg:gap-12">
      <div class="flex flex-col gap-6 text-[0.9375rem] text-cefa-gray leading-relaxed max-w-2xl">
        <p>{missionDescription}</p>
        <p>{missionDescription2}</p>
      </div>
    </div>
  </div>
</Section>

<!-- sección de estadísticas integrada (separada para el estilo de borde superior e inferior) -->
<Section background="white" padding="none" class="pb-8 lg:pb-12">
  <div class="grid grid-cols-2 lg:grid-cols-4 border-y border-cefa-navy/5">
    {
      stats.map((s, i) => (
        <StatItem
          value={s.value}
          label={s.label}
          delay={i * 100}
          class:list={[
            i < stats.length - 1 && 'lg:border-r lg:border-cefa-navy/5',
            i % 2 === 0 && 'border-r border-cefa-navy/5',
            i >= 2 && 'border-t border-cefa-navy/5 lg:border-t-0',
          ]}
        />
      ))
    }
  </div>
</Section>
