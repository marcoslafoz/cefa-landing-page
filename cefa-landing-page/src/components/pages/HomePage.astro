---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Hero from '@/components/Hero.astro';
import Mission from '@/components/Mission.astro';
import Innovation from '@/components/Innovation.astro';
import Products from '@/components/Products.astro';
import Quote from '@/components/Quote.astro';
import Clients from '@/components/Clients.astro';
import Vision from '@/components/Vision.astro';
import MapSection from '@/components/MapSection.astro';
import Contact from '@/components/Contact.astro';
import Careers from '@/components/Careers.astro';
import FAQ from '@/components/FAQ.astro';
import Footer from '@/components/Footer.astro';
import { useTranslations } from '@/i18n/translations';
import type { Locale } from '@/i18n/translations';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<Layout title={t('meta.title')} description={t('meta.description')} locale={locale}>
  <Header locale={locale} />
  <main id="main-content">
    <Hero locale={locale} />
    <Clients locale={locale} />
    <Mission locale={locale} />
    <Innovation locale={locale} />
    <Products locale={locale} />
    <Quote locale={locale} />
    <Vision locale={locale} />
    <MapSection locale={locale} />
    <Contact locale={locale} />
    <Careers locale={locale} />
    <FAQ locale={locale} />
  </main>
  <Footer locale={locale} />
</Layout>
