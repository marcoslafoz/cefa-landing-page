---
import type { Locale } from '@/i18n/translations';
import PageHeader from '@/components/ui/PageHeader.astro';
import History from '@/components/History.astro';
import { getHistoryContent } from '@/lib/cms';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const historyData = await getHistoryContent(locale);
---

<PageHeader
  eyebrow={historyData?.eyebrow ?? ''}
  title={historyData?.pageTitle ?? ''}
  description={historyData?.pageSubtitle ?? ''}
/>
<History locale={locale} />
