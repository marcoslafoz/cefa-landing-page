---
import type { Locale } from '@/i18n/translations';
import Section from '@/components/ui/Section.astro';
import { getHistoryContent } from '@/lib/cms';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const cmsHistory = await getHistoryContent(locale);

interface Milestone {
  id: string;
  label: string;
  numericYear: number | null;
  text: string;
}

const milestones: Milestone[] = (cmsHistory?.timeline ?? []).map(
  (m: { year?: string; text?: string }) => ({
    id: `y${m.year}`,
    label: m.year ?? '',
    numericYear: parseInt(m.year ?? '') || null,
    text: m.text ?? '',
  })
);

if (cmsHistory?.todayText) {
  milestones.push({
    id: 'today',
    label: cmsHistory.todayLabel ?? '',
    numericYear: null,
    text: cmsHistory.todayText,
  });
}
---

<Section id="history" background="white" padding="lg" class="pt-8! lg:pt-10!">
  <div class="reveal" aria-label="Timeline" role="tablist">
    <!-- Track -->
    <div
      class="overflow-x-auto -mx-6 md:-mx-10 px-6 md:px-10 pb-1 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
    >
      <div class="relative flex items-end min-w-max" id="history-track">
        <div class="absolute bottom-6.25 left-0 right-0 h-px bg-cefa-navy/10 pointer-events-none">
        </div>
        <div
          id="history-progress-line"
          class="absolute bottom-6.25 left-0 h-px bg-cefa-red/50 pointer-events-none transition-[width] duration-500 ease-in-out"
          style="width:0"
        >
        </div>
        {
          milestones.map(({ id, label }, i) => (
            <button
              class="history-btn group relative flex flex-col items-center gap-3 px-5 md:px-7 pt-2 pb-5 cursor-pointer"
              data-index={i}
              data-year={id}
              aria-selected={i === 0 ? 'true' : 'false'}
              role="tab"
            >
              <span class="text-[0.7rem] font-bold tracking-[0.12em] uppercase text-cefa-navy/25 group-[.is-active]:text-cefa-red transition-colors duration-300 select-none whitespace-nowrap">
                {label}
              </span>
              <span class="relative z-10 w-2.5 h-2.5 rounded-full border-2 border-cefa-navy/15 bg-white transition-all duration-300 group-[.is-active]:border-cefa-red group-[.is-active]:bg-cefa-red group-hover:border-cefa-navy/30" />
            </button>
          ))
        }
      </div>
    </div>

    <!-- Contenido: texto -->
    <div class="mt-12 max-w-2xl">
      <div class="flex gap-6 items-start">
        <div class="shrink-0 w-0.5 bg-cefa-red/30 rounded-full self-stretch min-h-35"></div>
        <div class="min-w-0">
          <p
            id="history-year-display"
            class="text-[clamp(2.5rem,6vw,3.5rem)] font-extralight text-cefa-red leading-none mb-4 tabular-nums"
            aria-live="polite"
          >
            {milestones[0].label}
          </p>
          <div class="h-30 md:h-25">
            <p
              id="history-text-display"
              class="text-[0.9375rem] text-cefa-gray leading-relaxed max-w-xl"
              aria-live="polite"
            >
              {milestones[0].text}
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Datos para JS -->
    <script
      is:inline
      id="history-data"
      type="application/json"
      set:html={JSON.stringify(
        milestones.map((m) => ({ label: m.label, numericYear: m.numericYear, text: m.text }))
      )}
    />
  </div>
</Section>

<script>
  function initHistory() {
    const buttons = document.querySelectorAll<HTMLButtonElement>('.history-btn');
    const progressLine = document.getElementById('history-progress-line');
    const track = document.getElementById('history-track');
    const yearDisplay = document.getElementById('history-year-display');
    const textDisplay = document.getElementById('history-text-display');
    const dataEl = document.getElementById('history-data');

    if (!buttons.length || !yearDisplay || !textDisplay || !dataEl) return;

    const data: { label: string; numericYear: number | null; text: string }[] = JSON.parse(
      dataEl.textContent || '[]'
    );

    let current = 0;
    let counterTimer: ReturnType<typeof setInterval> | null = null;

    /* ── helpers ── */
    function getProgressWidth(index: number): string {
      if (!track) return '0';
      const btn = buttons[index] as HTMLElement;
      const trackRect = track.getBoundingClientRect();
      const btnRect = btn.getBoundingClientRect();
      return `${btnRect.left - trackRect.left + btnRect.width / 2}px`;
    }

    /* Fade del texto */
    function fadeText(target: string) {
      textDisplay!.style.transition = 'opacity 0.15s ease';
      textDisplay!.style.opacity = '0';
      setTimeout(() => {
        textDisplay!.textContent = target;
        textDisplay!.style.transition = 'opacity 0.4s ease';
        textDisplay!.style.opacity = '1';
      }, 150);
    }

    /* Counter: anima el año de fromYear a toYear */
    function countYear(
      _fromLabel: string,
      fromNum: number | null,
      toLabel: string,
      toNum: number | null
    ) {
      if (counterTimer) clearInterval(counterTimer);

      if (toNum === null) {
        yearDisplay!.style.opacity = '0';
        setTimeout(() => {
          yearDisplay!.textContent = toLabel;
          yearDisplay!.style.transition = 'opacity 0.3s ease';
          yearDisplay!.style.opacity = '1';
        }, 80);
        return;
      }

      const start = fromNum ?? toNum;
      const end = toNum;
      const steps = 18;
      const stepVal = (end - start) / steps;
      let n = 0;

      counterTimer = setInterval(() => {
        n++;
        const val = n < steps ? Math.round(start + stepVal * n) : end;
        yearDisplay!.textContent = String(val);
        if (n >= steps) {
          clearInterval(counterTimer!);
          counterTimer = null;
        }
      }, 22);
    }

    /* ── activate ── */
    function activate(index: number) {
      if (index === current) return;

      const prev = current;
      current = index;

      buttons[prev].classList.remove('is-active');
      buttons[prev].setAttribute('aria-selected', 'false');
      buttons[current].classList.add('is-active');
      buttons[current].setAttribute('aria-selected', 'true');

      countYear(
        data[prev].label,
        data[prev].numericYear,
        data[current].label,
        data[current].numericYear
      );

      fadeText(data[current].text);

      if (progressLine) progressLine.style.width = getProgressWidth(current);

      buttons[current].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    }

    /* ── init ── */
    buttons[0].classList.add('is-active');
    if (progressLine) progressLine.style.width = getProgressWidth(0);
    textDisplay!.textContent = data[0].text;
    textDisplay!.style.opacity = '1';

    buttons.forEach((btn, i) => {
      btn.addEventListener('mouseenter', () => activate(i));
      btn.addEventListener('click', () => activate(i));
    });

    let resizeTimer: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        if (progressLine) progressLine.style.width = getProgressWidth(current);
      }, 100);
    });
  }

  document.addEventListener('astro:page-load', initHistory);
</script>
