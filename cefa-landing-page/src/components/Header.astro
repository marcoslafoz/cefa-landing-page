---
import type { Locale } from '@/i18n/translations';
import {
  useTranslations,
  getLocalePath,
  locales,
  localeNames,
  defaultLocale,
} from '@/i18n/translations';
import { getHeader } from '@/lib/cms';

interface Props {
  locale: Locale;
  showLogoAlways?: boolean;
}

const { locale, showLogoAlways = false } = Astro.props;
const t = useTranslations(locale);
const cmsHeader = await getHeader(locale);

const currentPath = Astro.url.pathname;
const isHome =
  currentPath === '/' || locales.some((l) => currentPath === `/${l}` || currentPath === `/${l}/`);

// Strip the current locale prefix to get the bare page path (e.g. /de/history → /history)
const barePagePath = (() => {
  if (locale === defaultLocale) return currentPath || '/';
  const stripped = currentPath.replace(new RegExp(`^/${locale}`), '') || '/';
  return stripped;
})();

// Transform CMS data to navItems format, or use fallbacks
const navData = cmsHeader?.items || [];

const navItems = navData.length > 0 
  ? navData.map((item: any) => ({
      label: item.label,
      href: item.isRelative ? getLocalePath(locale, item.href) : item.href,
      children: item.subItems?.map((sub: any) => ({
        label: sub.label,
        href: sub.isRelative ? getLocalePath(locale, sub.href) : sub.href
      }))
    }))
  : [
  {
    label: t('nav.company'),
    href: getLocalePath(locale, '/#mission'),
    children: [
      { label: t('nav.company.mission'), href: getLocalePath(locale, '/#mission') },
      { label: t('nav.company.vision'), href: getLocalePath(locale, '/#vision') },
      { label: t('nav.company.innovation'), href: getLocalePath(locale, '/#innovation') },
      { label: t('nav.company.history'), href: getLocalePath(locale, '/history') },
      { label: t('nav.company.awards'), href: getLocalePath(locale, '/awards') },
      { label: t('nav.presence'), href: getLocalePath(locale, '/#presence') },
      { label: t('nav.company.certifications'), href: getLocalePath(locale, '/certifications') },
      { label: t('nav.company.rd'), href: getLocalePath(locale, '/projects') },
    ],
  },
  {
    label: t('nav.products'),
    href: getLocalePath(locale, '/#products'),
    children: [
      { label: t('nav.products.dashboard'), href: getLocalePath(locale, '/#products') },
      { label: t('nav.products.door'), href: getLocalePath(locale, '/#products') },
      { label: t('nav.products.functional'), href: getLocalePath(locale, '/#products') },
      { label: t('nav.products.exterior'), href: getLocalePath(locale, '/#products') },
    ],
  },
  { label: t('nav.clients'), href: getLocalePath(locale, '/#clients') },
  {
    label: t('nav.contact'),
    href: getLocalePath(locale, '/#contact'),
    children: [
      { label: t('nav.contact.cta'), href: getLocalePath(locale, '/#contact') },
      { label: t('nav.careers'), href: getLocalePath(locale, '/#careers') },
      { label: t('nav.faq'), href: getLocalePath(locale, '/#faq') },
    ],
  },
];

const availableLocales = locales;
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  data-opaque="false"
  data-show-logo-always={showLogoAlways ? 'true' : 'false'}
>
  <div class="site-container">
    <div class="flex items-center justify-between h-18 gap-6">
      <!-- Logotipo -->
      <div
        id="header-logo"
        class="shrink-0 flex items-center gap-4 transition-all duration-300 opacity-0 pointer-events-none"
      >
        <a href={getLocalePath(locale)} aria-label="CEFA">
          <img
            src="/images/logos/cefa-color.svg"
            alt="CEFA"
            width="110"
            height="40"
            class="h-9 w-auto object-contain"
          />
        </a>
        <div class="h-6 w-px bg-white/10"></div>
        <div class="flex items-center">
          <a
            href="https://www.motherson.com/"
            target="_blank"
            rel="noopener noreferrer"
            class="opacity-70 hover:opacity-100 transition-opacity"
          >
            <img
              src="/images/logos/motherson.svg"
              alt="Motherson"
              width="120"
              height="28"
              class="h-6 w-auto brightness-0 invert"
            />
          </a>
        </div>
      </div>

      <!-- Navegación escritorio - Centrada completamente -->
      <nav
        class="hidden lg:flex items-center gap-1 absolute left-1/2 -translate-x-1/2"
        aria-label="Main navigation"
      >
        {
          navItems.map((item) => {
            const isCurrent = currentPath === item.href || item.isActive;
            return (
              <div class="relative group">
                <a
                  href={item.href}
                  aria-current={isCurrent ? 'page' : undefined}
                  class:list={[
                    'flex items-center gap-1 px-3 py-2 text-[11px] font-bold uppercase tracking-[0.15em] transition-colors duration-200 rounded',
                    isCurrent ? 'text-cefa-red' : 'text-white/85 hover:text-white',
                  ]}
                >
                  {item.label}
                  {item.children && (
                    <svg
                      class="w-3 h-3 transition-transform duration-200 group-hover:rotate-180"
                      viewBox="0 0 12 12"
                      fill="none"
                    >
                      <path
                        d="M2 4L6 8L10 4"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  )}
                </a>

                {item.children && (
                  <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 translate-y-1 group-hover:translate-y-0 z-50">
                    <ul class="bg-white border border-cefa-navy/6 rounded-none min-w-55 py-1.5 overflow-hidden">
                      {item.children.map((child) => (
                        <li>
                          <a
                            href={child.href}
                            class="flex items-center px-5 py-2.5 text-sm text-cefa-navy/70 hover:text-cefa-red border-l-2 border-transparent hover:border-cefa-red transition-all duration-150"
                          >
                            {child.label}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>
            );
          })
        }
      </nav>

      <!-- Derecha: idioma + CTA -->
      <div class="flex items-center gap-3 shrink-0">
        <!-- Selector de idioma -->
        <div class="relative group hidden md:block">
          <button
            class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold text-white/70 hover:text-white uppercase tracking-widest transition-colors duration-200"
            aria-label={t('nav.language')}
          >
            {locale.toUpperCase()}
            <svg
              class="w-3 h-3 transition-transform duration-200 group-hover:rotate-180"
              viewBox="0 0 12 12"
              fill="none"
            >
              <path
                d="M2 4L6 8L10 4"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </button>
          <div
            class="absolute top-full right-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 translate-y-1 group-hover:translate-y-0"
          >
            <ul
              class="bg-white border border-cefa-navy/10 rounded-none min-w-30 py-1.5 overflow-hidden"
            >
              {
                availableLocales.map((l) => (
                  <li>
                    <a
                      href={getLocalePath(l, barePagePath)}
                      class={`flex items-center px-4 py-2 text-sm transition-all duration-150 ${
                        l === locale
                          ? 'text-cefa-red font-bold bg-cefa-navy/5'
                          : 'text-cefa-navy/70 hover:text-cefa-red'
                      }`}
                      hreflang={l}
                      data-lang={l}
                    >
                      {localeNames[l]}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>

        <!-- Botón Menú (Burger) -->
        <button
          id="burger"
          class="lg:hidden flex flex-col gap-1.5 w-8 p-1 group"
          aria-label={t('nav.menu.open')}
          aria-expanded="false"
        >
          <span
            class="block w-full h-0.5 bg-white rounded transition-all duration-300 origin-center group-hover:transform-[translateY(8px)_rotate(45deg)]"
          ></span>
          <span
            class="block w-full h-0.5 bg-white rounded transition-all duration-300 group-hover:opacity-0"
          ></span>
          <span
            class="block w-5 h-0.5 bg-white rounded transition-all duration-300 origin-center group-hover:w-full group-hover:transform-[translateY(-8px)_rotate(-45deg)]"
          ></span>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Menú desplegable móvil -->
<nav
  id="mobile-nav"
  class="lg:hidden fixed inset-0 top-0 pt-20 bg-cefa-navy-dark z-40 translate-x-full transition-transform duration-300 overflow-y-auto"
  aria-hidden="true"
  inert
>
  <ul class="flex flex-col px-6 py-4 gap-1">
    {
      navItems.map((item) => (
        <li class="flex flex-col border-b border-white/8">
          <a
            href={item.href}
            class="flex items-center py-3.5 text-lg font-semibold text-white/80 hover:text-white transition-colors"
          >
            {item.label}
          </a>
          {item.children && (
            <ul class="flex flex-col pl-4 pb-4 gap-3">
              {item.children.map((child) => (
                <li>
                  <a
                    href={child.href}
                    class="text-[0.95rem] font-medium text-white/65 hover:text-white transition-colors"
                  >
                    {child.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))
    }
    <li class="pt-6 flex flex-col gap-3">
      {
        availableLocales.map((l) => (
          <a
            href={getLocalePath(l, barePagePath)}
            class={`text-sm font-semibold transition-colors ${
              l === locale ? 'text-cefa-red' : 'text-white/50 hover:text-white'
            }`}
            hreflang={l}
            data-lang={l}
          >
            {localeNames[l]}
          </a>
        ))
      }
    </li>
  </ul>
</nav>

<script>
  let headerController: AbortController | null = null;

  function initHeader() {
    headerController?.abort();
    headerController = new AbortController();
    const { signal } = headerController;

    const header = document.getElementById('site-header');
    const headerLogo = document.getElementById('header-logo');
    const burger = document.getElementById('burger');
    const mobileNav = document.getElementById('mobile-nav');

    if (!header || !burger || !mobileNav) return;

    const alwaysShowLogo = header.dataset.showLogoAlways === 'true';
    let isOpen = false;

    // Asegurar que el menú comience cerrado en cada carga de página
    mobileNav.classList.add('translate-x-full');
    mobileNav.classList.remove('translate-x-0');
    mobileNav.setAttribute('aria-hidden', 'true');
    mobileNav.setAttribute('inert', '');
    burger.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';

    function updateHeader() {
      const isScrolled = window.scrollY > 50;
      const showLogo = isScrolled || alwaysShowLogo || isOpen;

      header!.style.background = showLogo
        ? getComputedStyle(document.documentElement)
            .getPropertyValue('--color-cefa-header-bg')
            .trim()
        : 'transparent';
      header!.style.boxShadow = 'none';
      header!.style.backdropFilter = showLogo ? 'blur(16px)' : 'none';

      if (headerLogo) {
        headerLogo.style.opacity = showLogo ? '1' : '0';
        headerLogo.style.pointerEvents = showLogo ? 'auto' : 'none';
      }
    }

    window.addEventListener('scroll', updateHeader, { passive: true, signal });
    updateHeader();

    const animateBurger = (open: boolean) => {
      const spans = burger!.querySelectorAll('span');
      if (open) {
        spans[0].style.transform = 'translateY(8px) rotate(45deg)';
        spans[1].style.opacity = '0';
        spans[2].style.transform = 'translateY(-8px) rotate(-45deg)';
        spans[2].style.width = '100%';
      } else {
        spans[0].style.transform = '';
        spans[1].style.opacity = '';
        spans[2].style.transform = '';
        spans[2].style.width = '';
      }
    };

    const toggleMenu = () => {
      isOpen = !isOpen;
      updateHeader();

      if (isOpen) {
        mobileNav!.classList.remove('translate-x-full');
        mobileNav!.classList.add('translate-x-0');
        mobileNav!.setAttribute('aria-hidden', 'false');
        mobileNav!.removeAttribute('inert');
        burger!.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
        animateBurger(true);
      } else {
        mobileNav!.classList.add('translate-x-full');
        mobileNav!.classList.remove('translate-x-0');
        mobileNav!.setAttribute('aria-hidden', 'true');
        mobileNav!.setAttribute('inert', '');
        burger!.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
        animateBurger(false);
      }
    };

    burger.addEventListener('click', toggleMenu, { signal });

    mobileNav.querySelectorAll('a').forEach((link) => {
      link.addEventListener(
        'click',
        () => {
          if (isOpen) toggleMenu();
        },
        { signal }
      );
    });

    // Persistir la elección explícita de idioma para que la autodetección no la sobreescriba
    document.querySelectorAll<HTMLElement>('[data-lang]').forEach((el) => {
      el.addEventListener(
        'click',
        () => {
          const lang = el.dataset.lang;
          if (lang) localStorage.setItem('cefa-locale', lang);
        },
        { signal }
      );
    });
  }

  document.addEventListener('astro:page-load', initHeader);
  initHeader();
</script>
