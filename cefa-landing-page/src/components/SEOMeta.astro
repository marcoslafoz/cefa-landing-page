    ? [
        {
          '@type': 'VideoObject',
          name:
            locale === 'es'
              ? 'CEFA – Fabricante de Salpicaderos y Componentes Plásticos para Automoción'
              : locale === 'de'
                ? 'CEFA – Hersteller von Instrumententafeln und Kunststoffkomponenten für die Automobilindustrie'
                : locale === 'pl'
                  ? 'CEFA – Producent Desek Rozdzielczych i Komponentów z Tworzyw Sztucznych dla Motoryzacji'
