const fullSchema = { '@context': 'https://schema.org', '@graph': schemaGraph };
---

<!-- ── Meta básicos ──────────────────────────────────────────────────────── -->
<meta
  name="robots"
  content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1"
/>
<meta name="theme-color" content="#0a1f3c" />
<meta name="author" content="CEFA - Celulosa Fabril, SA" />
<meta name="format-detection" content="telephone=no" />
<meta name="keywords" content={pageKeywords} />

<!-- ── Geo (SEO local para sede de Zaragoza) ────────────────────────────── -->
<meta name="geo.region" content="ES-AR" />
<meta name="geo.placename" content="Zaragoza, España" />
<meta name="geo.position" content="41.6491;-0.8931" />
<meta name="ICBM" content="41.6491, -0.8931" />

<!-- ── Preloads ─────────────────────────────────────────────────────────── -->
<!-- LCP hero: solo homepage, imagen descubierta antes de parsear el CSS -->
{isHome && <link rel="preload" as="image" href="/images/mission/frame.webp" fetchpriority="high" />}
<!-- Fuente crítica: evita layout shift -->
<link
  rel="preload"
  href="/fonts/open-sans/open-sans-variable.woff2"
  as="font"
  type="font/woff2"
  crossorigin="anonymous"
/>

<!-- ── Preconnect ───────────────────────────────────────────────────────── -->
<link rel="preconnect" href="https://player.vimeo.com" />
<link rel="preconnect" href="https://i.vimeocdn.com" />
<link rel="preconnect" href="https://f.vimeocdn.com" />
<link rel="dns-prefetch" href="https://player.vimeo.com" />
<link rel="dns-prefetch" href="https://f.vimeocdn.com" />

<!-- ── Title y descripción ──────────────────────────────────────────────── -->
<title>{title}</title>
<meta name="description" content={description} />

<!-- ── Canonical y hreflang ─────────────────────────────────────────────── -->
<link rel="canonical" href={canonicalUrl} />
{hrefLangs.map(({ lang, href }) => <link rel="alternate" hreflang={lang} href={href} />)}
<link rel="alternate" hreflang="x-default" href={xDefaultHref} />

<!-- ── Open Graph ───────────────────────────────────────────────────────── -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageAbsolute} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta
  property="og:image:alt"
  content="CEFA manufacturing plant – plastic injection moulding for automotive OEMs"
/>
<meta property="og:site_name" content="CEFA" />
<meta property="og:locale" content={ogLocale} />
{
  locales
    .filter((l) => l !== locale)
    .map((l) => (
      <meta
        property="og:locale:alternate"
        content={l === 'es' ? 'es_ES' : l === 'en' ? 'en_GB' : l === 'de' ? 'de_DE' : 'pl_PL'}
      />
    ))
}
<!-- og:video (homepage): preview de vídeo en LinkedIn / Facebook / Slack -->
{
  isHome && (
    <>
      <meta property="og:video" content="https://player.vimeo.com/video/1181594121" />
      <meta property="og:video:secure_url" content="https://player.vimeo.com/video/1181594121" />
      <meta property="og:video:type" content="text/html" />
      <meta property="og:video:width" content="1280" />
      <meta property="og:video:height" content="720" />
    </>
  )
}

<!-- ── Twitter / X ──────────────────────────────────────────────────────── -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageAbsolute} />
<meta
  name="twitter:label1"
  content={locale === 'es'
    ? 'Fundada en'
    : locale === 'de'
      ? 'Gegründet'
      : locale === 'pl'
        ? 'Założona w'
        : 'Founded'}
/>
<meta name="twitter:data1" content="1946" />
<meta
  name="twitter:label2"
  content={locale === 'es'
    ? 'Empleados'
    : locale === 'de'
      ? 'Mitarbeiter'
      : locale === 'pl'
        ? 'Pracownicy'
        : 'Employees'}
/>
<meta name="twitter:data2" content="+800" />

<!-- ── Favicons ─────────────────────────────────────────────────────────── -->
<link rel="icon" type="image/png" href="/favicon/favicon-96x96.png" sizes="96x96" />
<link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
<link rel="shortcut icon" href="/favicon/favicon.ico" />
<link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
<meta name="apple-mobile-web-app-title" content="CEFA" />
<link rel="manifest" href="/favicon/site.webmanifest" />

<!-- ── JSON-LD @graph ───────────────────────────────────────────────────── -->
<!-- Organization · WebSite · WebPage · LocalBusiness×3 · Service · BreadcrumbList · VideoObject -->
<script is:inline type="application/ld+json" set:html={JSON.stringify(fullSchema)} />
