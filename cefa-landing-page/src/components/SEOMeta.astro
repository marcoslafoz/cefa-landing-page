---
/**
 * SEOMeta — todas las etiquetas <head> relacionadas con SEO y metadatos.
 *
 * Incluye:
 *  - meta básicos (robots, author, keywords, geo, theme-color)
 *  - preloads de recursos críticos (LCP image, fuente)
 *  - preconnect / dns-prefetch
 *  - <title> y meta description
 *  - canonical + hreflang (con x-default correcto por página)
 *  - Open Graph (og:type, og:image, og:video en homepage)
 *  - Twitter / X cards con label/data
 *  - Favicons + webmanifest
 *  - JSON-LD @graph (Organization, WebSite, WebPage, LocalBusiness×3,
 *                    Service, BreadcrumbList, VideoObject)
 */
import type { Locale } from '@/i18n/translations';
import { locales, getLocalePath } from '@/i18n/translations';
import { getSEO } from '@/lib/cms';

interface Props {
  title: string;
  description: string;
  locale: Locale;
  canonicalUrl?: string;
  ogImage?: string;
  keywords?: string;
}

const {
  title: propTitle,
  description: propDescription,
  locale,
  canonicalUrl = Astro.url.href,
  ogImage: propOgImage,
  keywords: propKeywords,
} = Astro.props;

const cmsSEO = await getSEO(locale);

const title = propTitle || cmsSEO?.title || 'CEFA Manufacturing';
const description = propDescription || cmsSEO?.description || '';
const keywords = propKeywords || cmsSEO?.keywords || '';
const ogImage = propOgImage || cmsSEO?.ogImage?.url || '/images/mission/zagan.webp';

const defaultKeywords: Record<string, string> = {
  es: 'inyección de plásticos automoción, fabricante salpicaderos plástico, paneles de puerta coche, componentes plásticos OEM, piezas plástico automóvil, revestimientos exteriores coche, proveedor Tier 1 automoción, IATF 16949, ISO 9001, fabricante plástico Zaragoza España',
  en: 'plastic injection moulding automotive, instrument panel manufacturer, dashboard plastic components, door panels OEM supplier, exterior automotive trims, functional plastic automotive, Tier 1 automotive supplier, IATF 16949, ISO 9001, plastic manufacturer Zaragoza Spain',
  de: 'Kunststoffspritzguss Automobilindustrie, Instrumententafel Hersteller, Türverkleidungen Automobilzulieferer, Kunststoffkomponenten OEM, Tier 1 Automobilzulieferer, IATF 16949, ISO 9001, Kunststoffhersteller Spanien',
  pl: 'wtrysk tworzyw sztucznych motoryzacja, producent desek rozdzielczych, panele drzwiowe OEM, komponenty z tworzyw sztucznych samochód, dostawca Tier 1 motoryzacja, IATF 16949, ISO 9001, producent tworzyw sztucznych Żagań Polska',
};
const pageKeywords = keywords ?? defaultKeywords[locale] ?? defaultKeywords['en'];

const siteBase = (Astro.site?.href ?? 'https://cefa.es').replace(/\/$/, '');

// og:image siempre absoluta (requerido por crawlers)
const ogImageAbsolute = ogImage.startsWith('http')
  ? ogImage
  : new URL(ogImage, Astro.site ?? Astro.url).href;

// Ruta sin prefijo de locale → permite hreflang correctos en subpáginas
const rawPath = (() => {
  const path = Astro.url.pathname;
  const match = path.match(/^\/(es|de|pl)(\/.*)?$/);
  if (match) return match[2] || '/';
  return path;
})();

const isHome = rawPath === '/' || rawPath === '';

const hrefLangs = locales.map((l) => ({
  lang: l,
  href: new URL(getLocalePath(l, rawPath), Astro.site ?? Astro.url).href,
}));

// x-default apunta a la versión EN de la página actual (no al homepage)
const xDefaultHref = new URL(getLocalePath('en', rawPath), Astro.site ?? Astro.url).href;

const localeCode =
  locale === 'en' ? 'en-GB' : locale === 'es' ? 'es-ES' : locale === 'de' ? 'de-DE' : 'pl-PL';

const ogLocale =
  locale === 'es' ? 'es_ES' : locale === 'en' ? 'en_GB' : locale === 'de' ? 'de_DE' : 'pl_PL';

// Todas las entidades interconectadas via @id para el Knowledge Graph de Google.
const schemaGraph: Record<string, unknown>[] = [
