              position: 1,
              name:
                locale === 'es'
                  ? 'Inicio'
                  : locale === 'pl'
                    ? 'Strona główna'
                    : locale === 'de'
                      ? 'Startseite'
                      : 'Home',
              item: new URL(getLocalePath(locale, '/'), Astro.site ?? Astro.url).href,
            },
            {
              '@type': 'ListItem',
              position: 2,
              name: title.split('|')[0].trim(),
