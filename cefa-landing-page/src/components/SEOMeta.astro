  },

  {
    '@type': 'Service',
    '@id': `${siteBase}/#service-injection`,
    serviceType: 'Plastic Injection Moulding for Automotive',
    name:
      locale === 'es'
        ? 'Inyección de plásticos para automoción'
        : locale === 'de'
          ? 'Kunststoffspritzguss für die Automobilindustrie'
          : locale === 'pl'
            ? 'Wtrysk tworzyw sztucznych dla motoryzacji'
            : 'Automotive Plastic Injection Moulding',
    description:
      locale === 'es'
        ? 'Fabricación de componentes plásticos por inyección de alta precisión para los principales OEM del sector automotriz: salpicaderos, paneles de puerta, revestimientos exteriores y aplicaciones funcionales.'
        : locale === 'de'
          ? 'Herstellung von hochpräzisen Kunststoffspritzgusskomponenten für führende Automobilindustrie-OEM: Instrumententafeln, Türverkleidungen, Außenverkleidungen und Funktionsbauteile.'
          : locale === 'pl'
            ? 'Produkcja precyzyjnych komponentów wtryskowych z tworzyw sztucznych dla czołowych OEM branży motoryzacyjnej: deski rozdzielcze, panele drzwiowe, okładziny zewnętrzne i aplikacje funkcjonalne.'
            : 'High-precision plastic injection moulding of components for leading automotive OEMs: instrument panels (dashboards), door panels, exterior trims and functional applications.',
