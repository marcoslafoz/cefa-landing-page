---
import type { Locale } from '@/i18n/translations';
import { useTranslations } from '@/i18n/translations';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import Section from '@/components/ui/Section.astro';
import ProductCard from '@/components/ui/ProductCard.astro';
import { getProductsSection, getMediaUrl } from '@/lib/cms';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const cmsSection = await getProductsSection(locale);

const sectionEyebrow = cmsSection?.sectionHeader?.eyebrow || t('products.eyebrow');
const sectionTitle = cmsSection?.sectionHeader?.title || t('products.title');
const sectionSubtitle = cmsSection?.sectionHeader?.subtitle || t('products.subtitle');
const sectionCta = cmsSection?.sectionHeader?.cta || t('products.cta');

const fallbackProducts = [
  {
    id: 'product-dashboard',
    category: 'Interior',
    title: t('products.p1.title'),
    desc: t('products.p1.desc'),
    image: '/images/products/dashboard.webp',
  },
  {
    id: 'product-door-panels',
    category: 'Interior',
    title: t('products.p2.title'),
    desc: t('products.p2.desc'),
    image: '/images/products/door-panels.webp',
  },
  {
    id: 'product-functional',
    category: 'Functional',
    title: t('products.p3.title'),
    desc: t('products.p3.desc'),
    image: '/images/products/functional.webp',
  },
  {
    id: 'product-exterior',
    category: 'Exterior',
    title: t('products.p4.title'),
    desc: t('products.p4.desc'),
    image: '/images/products/exterior.webp',
  },
];

type ProductItem = {
  id: string;
  category: string;
  title: string;
  desc: string;
  image: string;
  alt: string;
};

const cmsProducts = cmsSection?.products || [];

const products: ProductItem[] =
  cmsProducts.length > 0
    ? cmsProducts.map((p: any, i: number) => ({
        id: `product-${i}`,
        category: p.category || fallbackProducts[i]?.category || 'Producto',
        title: p.title,
        desc: p.description || '',
        image:
          getMediaUrl(p.image) || fallbackProducts[i]?.image || '/images/products/dashboard.webp',
        alt: p.title,
      }))
    : fallbackProducts.map((p) => ({ ...p, alt: p.title }));

const siteBase = 'https://cefa.es';

const productListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: sectionTitle,
  description: sectionSubtitle,
  numberOfItems: products.length,
  itemListElement: products.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Product',
      name: p.title,
      description: p.desc,
      image: `${siteBase}${p.image}`,
      url: `${siteBase}/#${p.id}`,
      category:
        p.category === 'Interior'
          ? 'Automotive Interior Plastics'
          : p.category === 'Functional'
            ? 'Automotive Functional Plastics'
            : 'Automotive Exterior Plastics',
      manufacturer: { '@id': `${siteBase}/#organization` },
      brand: { '@type': 'Brand', name: 'CEFA', '@id': `${siteBase}/#organization` },
    },
  })),
};
---

<Section id="products" background="white" padding="lg">
  <!-- Cabecera -->
  <SectionHeader
    layout="split"
    eyebrow={sectionEyebrow}
    title={sectionTitle}
    description={sectionSubtitle}
    class="mb-10"
  />

  <!-- Galería en acordeón -->
  <div class="flex flex-col lg:flex-row h-auto lg:h-125 gap-4 lg:gap-2">
    {
      products.map((product, i) => (
        <ProductCard {...product} ctaText={sectionCta} delay={i * 100} />
      ))
    }
  </div>
</Section>

<!-- Esquema ItemList de Productos — habilita resultados enriquecidos de productos en Google -->
<script is:inline type="application/ld+json" set:html={JSON.stringify(productListSchema)} />
