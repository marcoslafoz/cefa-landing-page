# ── Cloudflare Turnstile ─────────────────────────────────────────────────────
# Obtén tus claves en dash.cloudflare.com → Turnstile
# Las claves de prueba de abajo siempre pasan — reemplázalas en producción.

# Expuesta al navegador (segura como pública)
PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Nunca expuesta al navegador — solo servidor
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# ── Transport de envío ───────────────────────────────────────────────────────
# "console" → imprime en el servidor (desarrollo / por defecto)
# "smtp"    → envía por correo via Office 365
CONTACT_TRANSPORT=console

# ── SMTP — Office 365 ────────────────────────────────────────────────────────
# Solo necesario si CONTACT_TRANSPORT=smtp
# Requisito previo: activar "SMTP AUTH" en admin.microsoft.com para la cuenta
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=noreply@cefa.es
SMTP_PASS=tu_contraseña

# ── Payload CMS ───────────────────────────────────────────────────────────────
# URL base del servidor Payload CMS
PAYLOAD_CMS_URL=http://localhost:3000
